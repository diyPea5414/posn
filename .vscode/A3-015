#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>
#include <stdbool.h>
void swap(int* xp, int* yp){
    int temp = *xp;
    *xp = *yp;
    *yp = temp;
}

// An optimized version of Bubble Sort
void bubbleSort(int arr[], int n){
    int i, j;
    bool swapped;
    for (i = 0; i < n - 1; i++) {
        swapped = false;
        for (j = 0; j < n - i - 1; j++) {
            if (arr[j] > arr[j + 1]) {
                swap(&arr[j], &arr[j + 1]);
                swapped = true;
            }
        }

        // If no two elements were swapped by inner loop,
        // then break
        if (swapped == false)
            break;
    }
}


int main(){
    int inputtimes,i,total = 0,total_real = 0;
    scanf("%d\n",&inputtimes);
    int array[inputtimes];
    for(i = 0;i< inputtimes;i++){
        scanf("%d",&array[i]);
    }
    bubbleSort(array,inputtimes);
    for(i = 0;i< inputtimes;i++){
        total += array[i];
        total_real += total*2;
    }
    printf("%d",total_real);
}