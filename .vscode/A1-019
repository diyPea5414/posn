#include <stdio.h>
#include <string.h>

int main(){
    int numbers[3],i,allsame=0;
    for(i = 0;i < 3; i++){
       scanf("%d",&numbers[i]);
       if(i !=0 && numbers[0] == numbers[i])
       {
            allsame +=1;
       }
    }
    if (allsame == 2)
    {
        printf("all the same");
    }
    else if (allsame == 0)
    {
        printf("all different");
    }
    else
    {
        printf("neither");
    }
}
