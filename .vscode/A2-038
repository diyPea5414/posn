#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>
#include <stdbool.h>

int main(){
    int input;
    scanf("%d",&input);
    int chars = getchar();
    int i,j,temp[6];
    int firstround[3],secondround[3],higest[3],total = 0;
    for(i = 0;i< 3;i++){
        firstround[i] = 0;
        secondround[i] = 0;
    }
    for(j = 0;j < input; j++){
        for(i = 0;i < 6;i++){
            scanf("%d",&temp[i]);
        }
        for(i = 0;i < 3;i++){
            firstround[i] += temp[i];
            secondround[i] += temp[i+3];
        }
    }
    for(i = 0;i< 3;i++){
        if(firstround[i] >= secondround[i]){
            higest[i] = firstround[i];
        }
        else
        {
            higest[i] = secondround[i];
        }
        total += higest[i];
    }
    printf("%d\n",total);
    for(i = 0;i< 3;i++){
        printf("%d ",higest[i]);
    }
    printf("\n");
    if(higest[0] > higest[1] + higest[2]){
        printf("YES");
    }
    else
    {
        printf("NO");
    }
}