#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>
#include <stdbool.h>
int findsmallest(int array[],int num){
    int smallest = 999999,i;
    for(i = 0;i < num;i++){
        if(array[i] < smallest){
            smallest = array[i];
        }
    }
    return smallest;
}
int main(){
    int inputlines,inputrows,i,j;
    scanf("%d %d\n",&inputlines,&inputrows);
    int table[inputrows],num = 0;
    for(j = 0;j < inputrows;j++){
        table[j] = 0;
    }
    for(i = 0;i < inputlines;i++){
        int temp;
        scanf("%d",&temp);
        int getchars = getchar();
        table[temp-1]++;
        num = 0;
    }
    int allleft = 0;
    int numsmallest = findsmallest(table,inputrows);;
    for(j = 0;j < inputrows;j++){
        table[j] -= numsmallest;
        allleft += table[j];
    }
    printf("%d",allleft);
}