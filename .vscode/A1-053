#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

int main(){
    int temp ,num1[3] ,num2[3],i=0;
    char ch;
    while(2 == scanf("%d%c", &temp, &ch)){
        if(ch == '\n')
            break;
        else if(ch != ' '){
            fprintf(stderr, "Invalid input.\n");
            return -1;
        }
        num1[i] = temp;
        i++;
    }
    i = 0;
    while(2 == scanf("%d%c", &temp, &ch)){
        if(ch == '\n')
            break;
        else if(ch != ' '){
            fprintf(stderr, "Invalid input.\n");
            return -1;
        }
        num2[i] = temp;
        i++;
    }
    for(i = 0;i<3;i++){
        printf("%d ",(num1[i]+num2[i])/2);
    }
