#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

int main(){
    int moeny,i,numbank[3]= {1000,500,100},numbankdis[3]= {0,0,0};
    if (scanf("%d",&moeny)!= 1) return 0;
    if(moeny > 20000){
        printf("ERROR");
        return 0;
    }
    for(i = 0 ; i < 3 ; i++){
        int used = moeny / numbank[i];
        if(used >0){
            numbankdis[i] +=used;
            moeny -= used * numbank[i];
        }
    }
    if(moeny != 0){
        printf("ERROR");
        return 0;
    }
    for(i = 0 ; i < 3 ; i++){
        if(numbankdis[i] != 0){
            printf("%d = %d\n",numbank[i],numbankdis[i]);
        }
    }
}