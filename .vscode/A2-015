#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

int main(){
    int lenth,width,times,price;
    scanf("%d %d %d\n",&lenth,&width,&times);
    scanf("%d",&price);
    int dis = (lenth + width)*2*times;
    int disprice = (lenth + width)*2*times*price;
    printf("%d\n%d",dis,disprice);
}