#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

int main(){
    int inputclasses,inputhours;
    if(scanf("%d",&inputclasses) != 1) return 0;
    if(scanf("%d",&inputhours) != 1) return 0;
    if(inputhours == 0){
        printf("No teaching");
        return 0;
    }
    int hours = (inputhours*inputclasses)/60;
    int mins = (inputhours*inputclasses)%60;
    if(hours > 0){
        printf("%d hours",hours);
    }
    if(mins > 0){
        if(hours > 0){
            printf(" ");
        }
        printf("%d minutes",mins);
    }
}