#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

int main(){
    int input,i;
    scanf("%d",&input);
    int total = 35;
    input--;
    if(input > 0){
        for (i = 0; i < input; i++)
        {
            if(i>=0 && i < 9){
                total+=5;
            }    
            else if(i>=9){
                total+=8;
            }
        }
    }
    printf("%d",total);
}