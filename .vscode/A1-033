#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main(){
    int num,i,total=0;
    if (scanf("%d\n",&num) != 1){return 0;}
    for(i = 0; i < num-1;i++){
        char input;
        //printf("%d",i);
        scanf("%c\n",&input);
        
        //if (scanf("%c",&input) != 1){return 0;}
        if (input == 'A'||input == 'E'||input == 'I'||input == 'O'||input == 'U'){
            total++;
        }
    }
    printf("%d",total);
}