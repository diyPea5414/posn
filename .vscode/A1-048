#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

int main(){
    int power,i;
    if (scanf("%d",&power)!= 1) return 0;
    float total = 0.00;
    for(i = 0 ; i < power ; i++){
        if(i >= 1 && i <= 10){
            total += 5.00;
        }
        if(i >= 11 && i <= 50){
            total += 7.00;
        }
        if(i >= 51 && i <= 100){
            total += 10.00;
        }
        if(i >= 101 && i <= 200){
            total += 12.00;
        }
        if(i >= 201){
            total += 15.00;
        }
    }
}