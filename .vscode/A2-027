#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

int main(){
    int num;
    scanf("%d",&num);
    int temp,highest = 0,allscores[num],i,numhigh=0;
    for(i = 0 ; i < num ; i++){
        scanf("%d",&temp);
        allscores[i] = temp;
        if(temp > highest){
            highest = temp;
        }
    }
    
    for(i = 0 ; i < num ; i++){
        if(allscores[i] == highest){
            numhigh++;
        }
    }
    printf("%d\n%d",highest,numhigh);
}