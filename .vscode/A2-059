#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

int main(){
    char hastags[5][30] = {
        "TechTrends",
        "EcoLife",
        "FoodieHeaven",
        "FashionWeek",
        "HealthyLiving"
    };
    char growths[3][30] = {
        "GROWING",
        "DECLINING",
        "STABLE",
    };
    int inputrends,i,j,key,firstday,days;
    scanf("%d",&inputrends);
    scanf("%d",&days);
    long temp;
    long inputrendstotal[inputrends];
    long id[inputrends];
    long keys[inputrends];
    int highest = 0,highestkey = 0;
    for(i = 0;i < inputrends ; i++){
        inputrendstotal[i] = 0;
        scanf("%ld",&id[i]);
        for(j = 0;j < days ; j++){
            scanf("%ld",&temp);
            if(j == inputrends-1){
                if(firstday > temp){
                    key = 1;
                }
                else if(firstday < temp){
                    key = 0;
                }
                else 
                {
                    key = 2;
                }
                keys[i] = key;
            }
            else if(j == 0){
                firstday = temp;
            }
            inputrendstotal[i] += temp;
        }
        double total = (double)inputrendstotal[i];
        printf("%s: %ld total, %.2f avg, %s\n",hastags[id[i]-1],inputrendstotal[i],total/days,growths[keys[i]]);
        if(inputrendstotal[i] > highest){
            highest = inputrendstotal[i];
            highestkey = i;
        }
    }
    printf("Top performer: %s",hastags[id[highestkey]-1]);
    return 0;
}