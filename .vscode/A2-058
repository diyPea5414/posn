#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

int main(){
    int min,max,stuff,remainder,i,total;
    scanf("%d",&min);
    scanf("%d",&max);
    scanf("%d",&stuff);
    scanf("%d",&remainder);
    for(i = min ;i <= max ; i++){
        if(i % stuff == remainder){
            total++;
        }
    }
    printf("%d",remainder);
}