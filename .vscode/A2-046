#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>
#include <stdbool.h>

int main(){
    int input,i,num,numvowels = 0,max_consecutive = 0,higest_con = 0;
    scanf("%d\n",&input);
    int numvowelssave[input] , max_consecutive_save[input];
    for(i = 0; i < input ; i++){
        char inputcharacter[200];
        fgets(inputcharacter,200,stdin);
        for(num = 0; num < strlen(inputcharacter) ; num++){
            inputcharacter[num] = tolower(inputcharacter[num]);
            if(inputcharacter[num] == 'a' || inputcharacter[num] == 'e'||inputcharacter[num] == 'i' || inputcharacter[num] == 'o' || inputcharacter[num] == 'u'){
                numvowels++;
                max_consecutive++;
                //printf("%d",max_consecutive);
            }
            else
            {
                //printf("%d",max_consecutive);
                if(max_consecutive > higest_con){
                    higest_con = max_consecutive;
                }
                max_consecutive =0;
            }
        }
        numvowelssave[i] = numvowels;
        max_consecutive_save[i] = higest_con;
        numvowels = 0;
        max_consecutive = 0;
        higest_con = 0;
    }
    for(i = 0; i < input ; i++){
        printf("Line %d: vowels = %d, max_consecutive = %d\n",i+1,numvowelssave[i],max_consecutive_save[i]);
    }
}