#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <math.h>

int main(){
    char input[100];
    scanf("%s",input);
    int i,x=0,y=0;
    for(i = 0;i< strlen(input);i++){
        if(input[i]=='N'){
            y++;
        }
        else if(input[i]=='S'){
            y--;
        }
        else if(input[i]=='W'){
            x--;
        }
        else if(input[i]=='E'){
            x++;
        }
    }
    int total = abs(0-x)+abs(0-y);
    printf("%d %d %d",x,y,total);
}